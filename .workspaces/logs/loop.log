+        fontFamily: '"Inter", sans-serif',
+        fontSize: 8,
+        fontWeight: 'bold',
+        fill: item.color,
+        letterSpacing: 0.5,
+      }),
+    });
+    label.x = x + 8;
+    label.y = y + 3;
+    label.eventMode = 'none';
+    container.addChild(label);
+
+    const helper = new Text({
+      text: item.helper,
+      style: new TextStyle({
+        fontFamily: '"Inter", sans-serif',
+        fontSize: 7,
+        fill: '#64748b',
+      }),
+    });
+    helper.x = x + 8;
+    helper.y = y + 11;
+    helper.eventMode = 'none';
+    container.addChild(helper);
+  }
+
+  return container;
+}
